---
import BaseLayout from '../layouts/BaseLayout.astro';
import atelierData from './atelier.json'; 

// 1. JSON 데이터가 확실히 배열 구조임을 컴퓨터에게 알려주며 안전하게 가져옵니다.
const rawData = atelierData as any[];

// 2. 가져온 데이터를 날짜 최신순으로 정렬합니다.
const sortedItems = [...rawData].sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());

// 3. 화면에는 최대 16개만 잘라서 표시합니다.
const displayItems = sortedItems.slice(0, 16);
---

<BaseLayout title="Atelier">
  <div class="atelier-header"></div>

  <div class="atelier-grid" id="atelierGrid">
    {displayItems.length > 0 ? (
      displayItems.map(item => (
        <div class="atelier-card">
          
          {/* 1. 이미지 (VIEW DETAIL) 클릭 시 -> 엣지샵 상품으로 새 창 열기 */}
          <a href={item.shopLink} target="_blank" rel="noopener noreferrer" class="image-wrapper">
            <img src={item.image} alt={item.title} loading="lazy" />
            <div class="overlay">
              <span>VIEW DETAIL</span>
            </div>
          </a>
          
          <div class="info-area">
            <h3 class="item-title">{item.title}</h3>
            <p class="item-desc">{item.description}</p>
            
            {/* 2. EXPLORE 버튼 클릭 시 -> 내 웹사이트 글 주소로 현재 창 이동 */}
            <a href={item.postLink} class="item-link">EXPLORE →</a>
          </div>
        </div>
      ))
    ) : (
      <div class="empty-state">
        <p>작품을 준비 중입니다.</p>
      </div>
    )}
  </div>

  <style>
    .atelier-container {
      width: 100%;
      max-width: 900px; 
      margin-left: auto;
      margin-right: auto;
      padding: 2rem;
      box-sizing: border-box;
    }
    
    /* 검색창을 빼고 아카이브와 결을 맞춘 깔끔한 실선 */
    .atelier-header {
      margin-bottom: 4rem;
      border-bottom: 1px solid var(--border); 
      padding-bottom: 1.5rem; 
    }

    .atelier-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 40px 24px;
    }

    .atelier-card {
      display: flex;
      flex-direction: column;
    }

    .image-wrapper {
      position: relative;
      width: 100%;
      aspect-ratio: 1 / 1; 
      overflow: hidden;
      background-color: #f9f9f9;
      border: 1px solid var(--border);
      display: block; /* 링크 영역 확보 */
    }

    .image-wrapper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .overlay {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(255, 255, 255, 0.8);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .overlay span {
      font-size: 0.65rem;
      letter-spacing: 2px;
      color: var(--text);
    }

      .image-wrapper:hover img { 
       transform: scale(1.05); 
      }

      /* 오직 이미지 영역 자체에 마우스를 올렸을 때만 VIEW DETAIL 글씨가 뜹니다 */
      .image-wrapper:hover .overlay { 
        opacity: 1; 
      }

      /* (선택 사항) EXPLORE 글씨에 마우스를 대면 글씨만 살짝 또렷해지거나 밑줄이 가도록 팁을 추가합니다 */
      .item-link:hover {
        text-decoration: underline;
        color: var(--text);
      }

    .info-area {
      padding: 1.2rem 0;
    }

    .item-title {
      font-size: 0.95rem;
      font-weight: bold;
      margin: 0 0 0.5rem 0;
      color: var(--text);
    }

    .item-desc {
      font-size: 0.75rem;
      color: var(--gray);
      line-height: 1.5;
      margin: 0 0 1rem 0;
      display: -webkit-box;
      -webkit-line-clamp: 2; 
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .item-link {
      font-size: 0.65rem;
      color: var(--text);
      text-decoration: none;
      letter-spacing: 1px;
      font-weight: bold;
    }

    .empty-state {
      grid-column: 1 / -1;
      text-align: center;
      padding: 10rem 0;
      color: var(--gray);
      font-size: 0.8rem;
    }

    @media (max-width: 600px) {
      .atelier-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
    }
  </style>
</BaseLayout>